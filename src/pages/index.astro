---
// =============================================================================
//  PROPUESTA COMERCIAL CONFIDENCIAL — Melissa Mallea (Global66)
//  Layout "Presentación Ejecutiva": sidebar fijo + tabs (JS vanilla).
//  Mobile First · Astro + Tailwind CSS. SEO omitido a propósito.
// =============================================================================
import "../styles/global.css";

// --- Índice de navegación (sidebar + barra móvil) ---------------------------
const tabs = [
  { id: "diagnostico", n: "01", label: "Diagnóstico y Contexto" },
  { id: "soluciones",  n: "02", label: "El Sistema (Soluciones)" },
  { id: "inversion",   n: "03", label: "Inversión y Cronograma" },
];

// --- Datos del embudo (centralizados para edición rápida) -------------------
const modulos = [
  {
    n: "01",
    titulo: "Optimización de LinkedIn",
    puntos: [
      "Perfil LinkedIn Empresa optimizado (titular + acerca de + servicios + destacado).",
      "Optimización técnica del algoritmo. (Auditoría técnica de sus 4 pilares).",
    ],
  },
  {
    n: "02",
    titulo: "Prospección Orgánica",
    puntos: [
      "Script de Prospección: Conexión, Entrega de Valor y CTA.",
      "Calendario de Cadencia Diaria (60 min).",
    ],
  },
  {
    n: "03",
    titulo: "Estrategia de Contenido",
    puntos: [
      "Agente de Estrategia de Contenidos y Autoridad: Grilla mensual.",
      "Agente de Redacción y Entregables: Desarrollo de publicaciones.",
    ],
  },
];

const precios = [
  { item: "Setting y Optimización de LinkedIn", clp: "92.000" },
  { item: "Prospección Orgánica vía LinkedIn", clp: "116.000" },
  { item: "Estrategia Comercial y Contenido", clp: "152.000" },
];

const cronograma = [
  { semana: "Semana 1", hito: "Firma del contrato, pago de honorarios y análisis e investigación del caso." },
  { semana: "Semana 2", hito: "Entrega de la planificación de los servicios contratados." },
  { semana: "Semana 3", hito: "Ajustes según feedback del cliente." },
  { semana: "Semanas 4–8", hito: "Implementación y acompañamiento." },
];
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Propuesta a Melissa Mallea | Matías Laporta</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root { font-family: "Inter", ui-sans-serif, system-ui, sans-serif; }
      body { font-family: "Inter", ui-sans-serif, system-ui, sans-serif; }

      /* Estado activo del navegador de tabs (sidebar vs barra móvil) */
      .nav-side.tab-active {
        background: rgba(34, 211, 238, 0.1);
        color: #fff;
        box-shadow: inset 2px 0 0 #22d3ee;
      }
      .nav-side.tab-active .nav-num { color: #22d3ee; }
      .nav-top.tab-active {
        background: #06b6d4;
        color: #0f172a;
        border-color: #06b6d4;
      }

      /* Tarjetas plegables (<details>): oculta el marcador nativo */
      details > summary { list-style: none; }
      details > summary::-webkit-details-marker { display: none; }
    </style>
  </head>

  <body class="min-h-screen bg-[#0f172a] text-slate-300 antialiased">
    <!-- ===================================================================== -->
    <!-- SIDEBAR (FIJO en lg+)                                                   -->
    <!-- ===================================================================== -->
    <aside
      class="hidden lg:flex lg:fixed lg:inset-y-0 lg:left-0 lg:w-72 lg:flex-col z-30 border-r border-slate-800/80 bg-[#0b0f19]"
    >
      <!-- Encabezado de la propuesta -->
      <div class="border-b border-slate-800/80 px-6 py-7">
        <a href="https://matiaslaporta.com/" target="_blank" rel="noopener noreferrer">
          <img src="/logo-ml-inv.png" alt="Matías Laporta" class="mb-5 h-12 w-auto transition hover:opacity-80" />
        </a>
        <div class="flex items-center gap-2">
          <span class="h-2 w-2 rounded-full bg-yellow-400"></span>
          <span class="text-[11px] font-semibold tracking-widest text-slate-500 uppercase">
            Propuesta confidencial
          </span>
        </div>
        <h2 class="mt-3 text-lg font-bold leading-tight text-white">
          Propuesta a<br /><span class="text-yellow-400">Melissa Mallea</span>
        </h2>
      </div>

      <!-- Navegación -->
      <nav class="flex-1 overflow-y-auto px-3 py-5">
        <ul class="space-y-1">
          {
            tabs.map((t) => (
              <li>
                <button
                  type="button"
                  data-tab={t.id}
                  class="nav-side group flex w-full items-center gap-3 rounded-lg px-3 py-2.5 text-left text-sm font-medium text-slate-400 transition hover:bg-slate-800/50 hover:text-white"
                >
                  <span class="nav-num font-mono text-xs text-slate-600 tabular-nums transition">
                    {t.n}
                  </span>
                  <span>{t.label}</span>
                </button>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- Footer del sidebar -->
      <div class="border-t border-slate-800/80 px-6 py-5">
        <a
          href="https://calendar.app.google/mTu5R8CYQ7A2BKYZ7"
          target="_blank"
          rel="noopener noreferrer"
          class="block w-full rounded-lg bg-yellow-400 px-4 py-3 text-center text-sm font-semibold text-slate-900 transition hover:bg-yellow-300"
        >
          Agendar Kick-off
        </a>
      </div>
    </aside>

    <!-- ===================================================================== -->
    <!-- BARRA SUPERIOR MÓVIL (lg:hidden)                                        -->
    <!-- ===================================================================== -->
    <header class="lg:hidden sticky top-0 z-30 border-b border-slate-800/80 bg-[#0b0f19]/95 backdrop-blur">
      <div class="flex items-center justify-between px-4 py-4">
        <div class="flex items-center gap-2.5">
          <img src="/logo-ml-inv.png" alt="Matías Laporta" class="h-7 w-auto" />
          <h2 class="text-base font-bold text-white">
            Propuesta a <span class="text-yellow-400">Melissa Mallea</span>
          </h2>
        </div>
        <button
          id="menu-toggle"
          type="button"
          aria-label="Abrir menú"
          class="flex h-10 w-10 items-center justify-center rounded-lg border border-slate-700 text-slate-200 transition hover:bg-slate-800/50"
        >
          <svg id="menu-icon-open" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 6h16M4 12h16M4 18h16" stroke-linecap="round" />
          </svg>
          <svg id="menu-icon-close" class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M6 6l12 12M18 6L6 18" stroke-linecap="round" />
          </svg>
        </button>
      </div>

      <!-- Menú desplegable -->
      <div id="mobile-menu" class="hidden border-t border-slate-800/80 px-4 py-4">
        <div class="flex items-center gap-2 px-1">
          <span class="h-2 w-2 rounded-full bg-yellow-400" />
          <p class="text-[11px] font-semibold tracking-widest text-slate-500 uppercase">
            Propuesta confidencial
          </p>
        </div>
        <ul class="mt-3 space-y-1.5">
          {
            tabs.map((t) => (
              <li>
                <button
                  type="button"
                  data-tab={t.id}
                  class="nav-top flex w-full items-center gap-3 rounded-lg border border-slate-800 px-3 py-2.5 text-left text-sm font-medium text-slate-300 transition"
                >
                  <span class="font-mono text-xs text-slate-600 tabular-nums">{t.n}</span>
                  {t.label}
                </button>
              </li>
            ))
          }
        </ul>
        <a
          href="https://calendar.app.google/mTu5R8CYQ7A2BKYZ7"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 block w-full rounded-lg bg-yellow-400 px-4 py-3 text-center text-sm font-semibold text-slate-900 transition hover:bg-yellow-300"
        >
          Agendar Kick-off
        </a>
      </div>
    </header>

    <!-- ===================================================================== -->
    <!-- ÁREA DE CONTENIDO (scrolleable)                                         -->
    <!-- ===================================================================== -->
    <!-- Fondo de nodos animados (solo visible en tabs Resumen e Inversión) -->
    <canvas
      id="bg-nodes"
      class="pointer-events-none fixed top-0 left-0 z-0 hidden"
      aria-hidden="true"
    ></canvas>

    <main id="content-scroll" class="relative z-10 lg:ml-72 lg:h-screen lg:overflow-y-auto">
      <div class="mx-auto flex min-h-screen max-w-6xl flex-col justify-center px-6 py-14 sm:px-10 sm:py-16 lg:px-16 lg:py-24">

        <!-- ============================ TAB 01 ============================ -->
        <!-- DIAGNÓSTICO Y CONTEXTO (Hero + PAS + Autoridad + Comparativa)      -->
        <section data-panel="diagnostico">

          <!-- ----- Bloque A: El Gancho (Hero) ----- -->
          <div>
            <p class="text-sm font-semibold tracking-widest text-cyan-400 uppercase">
              Propuesta Comercial Exclusiva para Melissa Mallea · Global66
            </p>
            <h1 class="mt-6 text-balance text-4xl font-bold leading-[1.1] tracking-tight text-white sm:text-5xl lg:text-6xl">
              De Hunter a Líder del Mercado: Automatización, Autoridad y
              <span class="text-yellow-400">Cierre en LinkedIn.</span>
            </h1>
            <p class="mt-8 max-w-3xl text-lg leading-relaxed text-slate-400 lg:text-xl">
              Cómo transformar tu perfil en un
              <span class="font-medium text-slate-200">imán de tomadores de decisión</span>
              y estructurar un sistema de prospección B2B predecible que convierta conexiones en
              llamadas de negocio, invirtiendo solo
              <span class="font-medium text-slate-200">60 minutos al día.</span>
            </p>
            <div class="mt-10 flex flex-col gap-4 sm:flex-row">
              <button
                type="button"
                data-tab="soluciones"
                class="inline-flex items-center justify-center rounded-lg bg-cyan-500 px-7 py-3.5 text-sm font-semibold text-slate-900 transition hover:bg-cyan-400"
              >
                Ver el sistema
              </button>
              <button
                type="button"
                data-tab="inversion"
                class="inline-flex items-center justify-center rounded-lg border border-slate-700 px-7 py-3.5 text-sm font-semibold text-slate-200 transition hover:border-slate-500 hover:bg-slate-800/50"
              >
                Inversión y cronograma
              </button>
            </div>
          </div>

          <!-- ----- Bloque B: El Diagnóstico del Escenario Actual (Pain Points) ----- -->
          <div class="mt-16 border-t border-slate-800/60 py-16">
            <p class="text-sm font-semibold tracking-widest text-cyan-400 uppercase">
              El Diagnóstico
            </p>
            <h2 class="mt-5 max-w-5xl text-3xl font-bold leading-snug tracking-tight text-white sm:text-4xl lg:text-5xl">
              El desafío del Hunter B2B moderno<br />
              en la <span class="text-yellow-400">era de la saturación.</span>
            </h2>
            <div class="mt-8 max-w-3xl space-y-5 text-base leading-relaxed text-slate-400 lg:text-lg">
              <p>
                Como Sales Specialist Hunter B2B, tu día a día exige precisión, velocidad y, sobre
                todo, una tasa de conversión alta. El mercado corporativo actual ignora los mensajes
                fríos y genéricos. La venta B2B no ocurre en la bandeja de entrada,
                <span class="text-slate-200">ocurre donde reside tu reputación.</span>
              </p>
              <p>
                Tras analizar el ecosistema digital y los objetivos comerciales, identificamos
                <span class="text-slate-200">tres brechas críticas</span> que frenan el potencial de
                captación a gran escala:
              </p>
            </div>

            <div class="mt-10 space-y-10">
              <!-- Sub-bloque 1 -->
              <div class="border-l-2 border-cyan-500/40 pl-5 sm:pl-6">
                <h3 class="text-lg font-semibold text-white lg:text-xl">
                  La Paradoja del Perfil Pasivo.
                </h3>
                <p class="mt-3 max-w-3xl text-base leading-relaxed text-slate-400 lg:text-lg">
                  Un perfil de LinkedIn que se lee como un currículum vitae atrae reclutadores, no
                  clientes corporativos. Tu perfil debe operar como una
                  <span class="text-slate-200">landing page de ventas personal</span> que posicione
                  tu autoridad desde el primer segundo.
                </p>
              </div>

              <!-- Sub-bloque 2 -->
              <div class="border-l-2 border-cyan-500/40 pl-5 sm:pl-6">
                <h3 class="text-lg font-semibold text-white lg:text-xl">
                  El "Ruido" en la Prospección.
                </h3>
                <p class="mt-3 max-w-3xl text-base leading-relaxed text-slate-400 lg:text-lg">
                  Enviar mensajes sin una estructura definida diluye la
                  urgencia. Se requiere un guion que conecte el dolor del cliente con tu solución en
                  tres pasos exactos:
                  <span class="text-slate-200">Conexión genuina, Entrega de valor inmediato y
                  Llamado a la acción (CTA) directo.</span>
                </p>
              </div>

              <!-- Sub-bloque 3 -->
              <div class="border-l-2 border-yellow-400/50 pl-5 sm:pl-6">
                <h3 class="text-lg font-semibold text-white lg:text-xl">
                  El Costo de Oportunidad en la Creación de Contenido.
                </h3>
                <p class="mt-3 max-w-3xl text-base leading-relaxed text-slate-400 lg:text-lg">
                  Generar visibilidad demanda tiempo que un Hunter de alto rendimiento debería pasar
                  cerrando tratos, no diseñando grillas. La falta de consistencia debilita el
                  <strong class="font-semibold text-yellow-400">algoritmo</strong> y reduce el alcance orgánico de tu cuenta.
                </p>
              </div>
            </div>
          </div>

          <!-- ----- Bloque C: La Oportunidad (Sistema de 3 Pilares) ----- -->
          <div class="border-t border-slate-800/60 py-16">
            <div class="grid gap-8 lg:grid-cols-2 lg:gap-14">
              <div>
                <p class="text-sm font-semibold tracking-widest text-cyan-400 uppercase">
                  La Oportunidad
                </p>
                <h2 class="mt-5 text-3xl font-bold leading-snug tracking-tight text-white sm:text-4xl lg:text-5xl">
                  El Sistema de 3 Pilares: Eficiencia, Algoritmo y
                  <span class="text-yellow-400">Mensajes de Impacto.</span>
                </h2>
              </div>
              <div class="space-y-5 text-lg leading-relaxed text-slate-400 lg:pt-2 lg:text-xl">
                <p>
                  La solución no es trabajar más horas, es optimizar los activos que ya posees. Al
                  alinear el algoritmo de LinkedIn con una metodología de prospección ágil y el poder
                  de la <span class="text-slate-200">Inteligencia Artificial entrenada a tu medida</span>,
                  creamos un embudo comercial invisible.
                </p>
                <p>
                  Este ecosistema te permitirá "hackear" tu algoritmo, elevar la
                  confianza de tus prospectos corporativos y delegar la carga operativa de la
                  redacción a modelos de IA especializados, permitiéndote concentrarte exclusivamente
                  en lo que mejor haces:
                  <span class="text-slate-200">cerrar cuentas clave.</span>
                </p>
              </div>
            </div>
          </div>
        </section>

        <!-- ============================ TAB 02 ============================ -->
        <section data-panel="soluciones" class="hidden">
          <p class="text-sm font-semibold tracking-widest text-cyan-400 uppercase">
            El Sistema
          </p>
          <h2 class="mt-5 text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl lg:whitespace-nowrap">
            3 pilares para un embudo <span class="text-yellow-400">predecible</span>.
          </h2>
          <div class="mt-12 space-y-4">
            {
              modulos.map((m) => (
                <details class="group rounded-xl border border-slate-800 bg-[#0b0f19]/60 transition duration-300 hover:border-yellow-400/40 hover:shadow-[0_0_35px_-8px_rgba(250,204,21,0.45)] open:border-yellow-400/30">
                  <summary class="flex cursor-pointer items-center gap-4 p-6 sm:gap-6">
                    <span class="font-mono text-2xl font-bold text-cyan-400/80 tabular-nums">
                      {m.n}
                    </span>
                    <h3 class="flex-1 text-lg font-semibold text-white lg:text-xl">{m.titulo}</h3>
                    <svg
                      class="h-5 w-5 shrink-0 text-slate-500 transition-transform duration-300 group-open:rotate-180"
                      viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"
                    >
                      <path d="M6 8l4 4 4-4" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </summary>
                  <div class="px-6 pb-6">
                    <ul class="space-y-2.5 border-t border-slate-800/80 pt-5">
                      {m.puntos.map((p) => (
                        <li class="flex gap-3 text-sm leading-relaxed text-slate-400 lg:text-base">
                          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-cyan-400/70" />
                          <span>{p}</span>
                        </li>
                      ))}
                    </ul>
                    {m.bonus && (
                      <p class="mt-5 inline-flex flex-wrap items-center gap-2 rounded-lg border border-yellow-400/20 bg-yellow-400/5 px-3 py-1.5 text-sm">
                        <span class="text-xs font-bold tracking-wide text-yellow-400 uppercase">Bonus</span>
                        <span class="text-slate-300">{m.bonus}</span>
                      </p>
                    )}
                  </div>
                </details>
              ))
            }
          </div>
        </section>

        <!-- ============================ TAB 03 ============================ -->
        <section data-panel="inversion" class="hidden">
          <p class="text-sm font-semibold tracking-widest text-cyan-400 uppercase">
            Inversión
          </p>
          <h2 class="mt-5 text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
            Inversión y <span class="text-yellow-400">cronograma</span>.
          </h2>

          <!-- Desglose + ofertas -->
          <div class="mt-10 grid gap-6 lg:grid-cols-[3fr_2fr]">
            <!-- Módulos individuales -->
            <div class="rounded-xl border border-slate-800 bg-[#0b0f19]/60 p-6 transition duration-300 hover:border-yellow-400/40 hover:shadow-[0_0_35px_-8px_rgba(250,204,21,0.4)] sm:p-7">
              <h3 class="text-xs font-semibold tracking-widest text-slate-400 uppercase">
                Módulos individuales
              </h3>
              <ul class="mt-5 divide-y divide-slate-800">
                {
                  precios.map((p) => (
                    <li class="flex items-baseline justify-between gap-4 py-3">
                      <span class="text-sm text-slate-300">{p.item}</span>
                      <span class="text-right whitespace-nowrap">
                        <span class="font-semibold text-white tabular-nums">${p.clp}</span>
                      </span>
                    </li>
                  ))
                }
              </ul>
              <div class="mt-4 flex items-baseline justify-between border-t border-slate-700 pt-4">
                <span class="text-sm font-semibold tracking-wide text-slate-200 uppercase">Total</span>
                <span class="text-right">
                  <span class="text-xl font-bold text-white tabular-nums">$360.000</span>
                </span>
              </div>
            </div>

            <!-- Ofertas -->
            <div class="space-y-5">
              <!-- Paquete completo (destacada) -->
              <div class="relative overflow-hidden rounded-xl border border-yellow-400/50 bg-gradient-to-b from-yellow-400/10 to-[#0b0f19]/60 p-6 transition duration-300 hover:border-cyan-400/60 hover:shadow-[0_0_35px_-8px_rgba(34,211,238,0.45)]">
                <span class="absolute right-4 top-4 rounded-full bg-yellow-400 px-3 py-1 text-xs font-bold text-slate-900">
                  30% OFF
                </span>
                <h3 class="text-base font-semibold text-yellow-400">Paquete Completo · 3 Módulos</h3>
                <p class="mt-4 flex items-baseline gap-2">
                  <span class="text-3xl font-bold text-white tabular-nums">$252.000</span>
                  <span class="text-sm text-slate-500 line-through">$360.000</span>
                </p>
                <p class="mt-4 text-sm text-slate-300">
                  Contrata los tres pilares del sistema y aplica un 30% de descuento sobre el total
                  combinado. El sistema completo, de extremo a extremo.
                </p>
              </div>
            </div>
          </div>

          <!-- Métodos de pago -->
          <div class="mt-10">
            <h3 class="text-xs font-semibold tracking-widest text-cyan-400 uppercase">
              Métodos de pago
            </h3>
            <div class="mt-5 flex flex-wrap gap-3">
              {
                [
                  "Transferencia bancaria",
                  "Tarjeta de Crédito (Pago en cuotas)",
                  "Criptomonedas (BTC y StableCoins L2)",
                ].map((m) => (
                  <span class="rounded-lg border border-slate-800 bg-[#0b0f19]/60 px-4 py-2 text-sm text-slate-300 transition duration-300 hover:border-yellow-400/40 hover:shadow-[0_0_25px_-8px_rgba(250,204,21,0.45)]">
                    {m}
                  </span>
                ))
              }
            </div>
          </div>

          <!-- Cronograma -->
          <div class="mt-12">
            <h3 class="text-xs font-semibold tracking-widest uppercase">
              <span class="text-cyan-400">Cronograma</span>
              <span class="text-slate-400">· 8 semanas</span>
            </h3>
            <ol class="mt-7 space-y-0 border-l border-slate-800">
              {
                cronograma.map((c) => (
                  <li class="relative pb-7 pl-7 last:pb-0">
                    <span class="absolute -left-[5px] top-1.5 h-2.5 w-2.5 rounded-full bg-cyan-400 ring-4 ring-[#0f172a]" />
                    <p class="text-sm font-semibold text-yellow-400">{c.semana}</p>
                    <p class="mt-1 text-sm leading-relaxed text-slate-400">{c.hito}</p>
                  </li>
                ))
              }
            </ol>
          </div>

          <!-- CTA final -->
          <div class="mt-14 rounded-2xl border border-slate-800 bg-[#0b0f19]/60 px-6 py-12 text-center transition duration-300 hover:border-yellow-400/40 hover:shadow-[0_0_35px_-8px_rgba(250,204,21,0.4)] sm:px-10">
            <h3 class="text-balance text-2xl font-bold tracking-tight text-white sm:text-3xl lg:text-4xl">
              Transformemos tu perfil de Hunter en
              <span class="text-yellow-400">un embudo que vende.</span>
            </h3>
            <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-slate-400">
              Empecemos por una sesión de Kick-off para definir el alcance, detalles y prioridades del
              proyecto.
            </p>
            <a
              href="https://calendar.app.google/mTu5R8CYQ7A2BKYZ7"
              target="_blank"
              rel="noopener noreferrer"
              class="mt-8 inline-flex items-center justify-center rounded-lg bg-yellow-400 px-9 py-4 text-base font-semibold text-slate-900 transition hover:bg-yellow-300"
            >
              Agenda tu Kick-off
            </a>
          </div>
        </section>

      </div>
    </main>

    <!-- ===================================================================== -->
    <!-- LÓGICA DE TABS (JavaScript Vanilla)                                     -->
    <!-- ===================================================================== -->
    <script>
      // ====================================================================
      //  NAVEGACIÓN POR TABS
      // ====================================================================
      const buttons = document.querySelectorAll("[data-tab]");
      const panels = document.querySelectorAll("[data-panel]");
      const scroller = document.getElementById("content-scroll");

      // Tabs que muestran el fondo de nodos animados (inicio y cierre).
      const NODE_TABS = new Set(["diagnostico", "inversion"]);

      function activate(id) {
        // Muestra/oculta paneles
        panels.forEach((panel) => {
          panel.classList.toggle("hidden", panel.dataset.panel !== id);
        });
        // Marca el botón activo en todos los navegadores (sidebar + móvil)
        buttons.forEach((btn) => {
          const isActive = btn.dataset.tab === id;
          btn.classList.toggle("tab-active", isActive);
          if (isActive) btn.setAttribute("aria-current", "page");
          else btn.removeAttribute("aria-current");
        });
        // Activa/desactiva el fondo de nodos según la pestaña
        nodes.setActive(NODE_TABS.has(id));
        // Cierra el menú móvil al navegar
        setMenu(false);
        // Vuelve arriba al cambiar de sección
        scroller?.scrollTo({ top: 0, behavior: "smooth" });
        window.scrollTo({ top: 0, behavior: "smooth" });
      }

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => activate(btn.dataset.tab));
      });

      // ====================================================================
      //  MENÚ SÁNDWICH (móvil)
      // ====================================================================
      const mobileMenu = document.getElementById("mobile-menu");
      const menuToggle = document.getElementById("menu-toggle");
      const iconOpen = document.getElementById("menu-icon-open");
      const iconClose = document.getElementById("menu-icon-close");
      function setMenu(open) {
        if (!mobileMenu) return;
        mobileMenu.classList.toggle("hidden", !open);
        iconOpen?.classList.toggle("hidden", open);
        iconClose?.classList.toggle("hidden", !open);
      }
      menuToggle?.addEventListener("click", () => {
        setMenu(mobileMenu.classList.contains("hidden"));
      });

      // ====================================================================
      //  FONDO DE NODOS ANIMADOS E INTERACTIVOS (canvas vanilla)
      // ====================================================================
      const nodes = (() => {
        const canvas = document.getElementById("bg-nodes");
        const ctx = canvas.getContext("2d");
        const prefersReduced = window.matchMedia(
          "(prefers-reduced-motion: reduce)"
        ).matches;

        let dpr = 1;
        let w = 0;
        let h = 0;
        let offsetLeft = 0;
        let particles = [];
        let raf = null;
        let active = false;
        let count = 46;
        const mouse = { x: null, y: null };

        // Parámetros idénticos a matiaslaporta.com (#network-canvas)
        const SIDEBAR_W = 288; // w-72 = 18rem = 288px
        const COUNT_DESKTOP = 46; // nodos en desktop (−35% respecto a los 70 originales)
        const COUNT_MOBILE = 20; // nodos en móvil
        const LINK_DIST = 120; // distancia para unir nodos entre sí
        const MOUSE_DIST = 180; // radio de interacción con el cursor
        const COLOR = "0, 229, 255"; // #00E5FF

        function resize() {
          // El <canvas> es un elemento reemplazado: NO se estira con inset CSS.
          // Lo dimensionamos explícitamente para cubrir el área de contenido.
          dpr = Math.min(window.devicePixelRatio || 1, 2);
          const isLg = window.matchMedia("(min-width: 1024px)").matches;
          offsetLeft = isLg ? SIDEBAR_W : 0;
          count = isLg ? COUNT_DESKTOP : COUNT_MOBILE;
          w = window.innerWidth - offsetLeft;
          h = window.innerHeight;
          canvas.style.left = offsetLeft + "px";
          canvas.style.width = w + "px";
          canvas.style.height = h + "px";
          canvas.width = Math.round(w * dpr);
          canvas.height = Math.round(h * dpr);
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          seed();
        }

        function seed() {
          // Cantidad de nodos según el dispositivo (móvil vs desktop)
          particles = Array.from({ length: count }, () => ({
            x: Math.random() * w,
            y: Math.random() * h,
            vx: (Math.random() - 0.5) * 1.5,
            vy: (Math.random() - 0.5) * 1.5,
            radius: Math.random() * 2 + 1,
          }));
        }

        function step() {
          ctx.clearRect(0, 0, w, h);

          // 1) Mover y dibujar cada nodo
          particles.forEach((p) => {
            p.x += p.vx;
            p.y += p.vy;
            if (p.x < 0 || p.x > w) p.vx *= -1;
            if (p.y < 0 || p.y > h) p.vy *= -1;
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.radius, 0, Math.PI * 2);
            ctx.fillStyle = "#00E5FF";
            ctx.fill();
          });

          // 2) Líneas hacia el cursor + entre nodos
          for (let i = 0; i < particles.length; i++) {
            // Línea hacia el cursor (sin atracción, solo conexión visual)
            if (mouse.x != null) {
              const sx = particles[i].x - mouse.x;
              const sy = particles[i].y - mouse.y;
              const l = Math.sqrt(sx * sx + sy * sy);
              if (l < MOUSE_DIST) {
                ctx.beginPath();
                ctx.strokeStyle = `rgba(${COLOR}, ${0.5 * (1 - l / MOUSE_DIST)})`;
                ctx.lineWidth = 1.5;
                ctx.moveTo(particles[i].x, particles[i].y);
                ctx.lineTo(mouse.x, mouse.y);
                ctx.stroke();
              }
            }
            // Líneas entre nodos cercanos
            for (let j = i; j < particles.length; j++) {
              const dx = particles[i].x - particles[j].x;
              const dy = particles[i].y - particles[j].y;
              const d = Math.sqrt(dx * dx + dy * dy);
              if (d < LINK_DIST) {
                ctx.beginPath();
                ctx.strokeStyle = `rgba(${COLOR}, ${0.2 * (1 - d / LINK_DIST)})`;
                ctx.lineWidth = 1;
                ctx.moveTo(particles[i].x, particles[i].y);
                ctx.lineTo(particles[j].x, particles[j].y);
                ctx.stroke();
              }
            }
          }

          raf = requestAnimationFrame(step);
        }

        function start() {
          if (raf || prefersReduced) return;
          raf = requestAnimationFrame(step);
        }

        function stop() {
          if (raf) cancelAnimationFrame(raf);
          raf = null;
        }

        function setActive(on) {
          active = on;
          canvas.classList.toggle("hidden", !on);
          if (on) {
            resize();
            if (prefersReduced) {
              // Render estático único si el usuario reduce movimiento
              step();
              stop();
            } else {
              start();
            }
          } else {
            stop();
            ctx.clearRect(0, 0, w, h);
          }
        }

        // Eventos
        window.addEventListener("resize", () => {
          if (active) resize();
        });
        function onMove(clientX, clientY) {
          mouse.x = clientX - offsetLeft;
          mouse.y = clientY;
        }
        window.addEventListener("pointermove", (e) => onMove(e.clientX, e.clientY));
        window.addEventListener("pointerleave", () => {
          mouse.x = null;
          mouse.y = null;
        });

        return { setActive };
      })();

      // Tab 1 visible por defecto + estilo activo + nodos encendidos
      activate("diagnostico");
    </script>
  </body>
</html>
